# Development Dockerfile for SIS RUA Unified
FROM node:22-slim

WORKDIR /app

# Install Python and development dependencies (minimal)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Install Python dependencies
COPY py_engine/requirements.txt ./py_engine/
RUN pip install --no-cache-dir --upgrade pip --break-system-packages && \
    pip install --no-cache-dir -r py_engine/requirements.txt --break-system-packages

# Copy package files and install deps
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Create necessary directories for volumes
RUN mkdir -p /app/public/dxf /app/cache /app/logs && \
    chown -R appuser:appuser /app/public /app/cache /app/logs

# Copy entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Environment variables for dev
ENV NODE_ENV=development \
    PORT=3001 \
    PYTHON_COMMAND=python3 \
    DOCKER_ENV=true

EXPOSE 3000
EXPOSE 3001

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
