{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bt_calculate_response.schema.json",
  "title": "BtCalculateResponse",
  "description": "Output from BT radial network calculation (BtRadialCalculationOutput).",
  "type": "object",
  "required": ["qtTrafo", "nodeResults", "terminalResults", "worstCase", "totalDemandKva", "consistencyAlerts"],
  "additionalProperties": false,
  "properties": {
    "qtTrafo": {
      "type": "number",
      "description": "Voltage drop at transformer root (% or per-unit, per workbook convention)."
    },
    "nodeResults": {
      "type": "array",
      "items": { "$ref": "#/definitions/BtRadialNodeResult" }
    },
    "terminalResults": {
      "type": "array",
      "items": { "$ref": "#/definitions/BtRadialTerminalResult" }
    },
    "worstCase": {
      "$ref": "#/definitions/BtRadialWorstCase"
    },
    "totalDemandKva": {
      "type": "number",
      "minimum": 0,
      "description": "Total accumulated demand at transformer root in kVA."
    },
    "consistencyAlerts": {
      "type": "array",
      "items": { "$ref": "#/definitions/BtRadialConsistencyAlert" }
    }
  },
  "definitions": {
    "BtRadialNodeResult": {
      "type": "object",
      "required": ["nodeId", "qtSegment", "qtAccumulated", "voltageV", "accumulatedDemandKva", "pathFromRoot"],
      "additionalProperties": false,
      "properties": {
        "nodeId": { "type": "string", "minLength": 1 },
        "qtSegment": { "type": "number" },
        "qtAccumulated": { "type": "number" },
        "voltageV": { "type": "number" },
        "accumulatedDemandKva": { "type": "number", "minimum": 0 },
        "pathFromRoot": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "BtRadialTerminalResult": {
      "type": "object",
      "required": ["nodeId", "qtTerminal", "qtRamal", "qtTotal", "voltageEndV"],
      "additionalProperties": false,
      "properties": {
        "nodeId": { "type": "string", "minLength": 1 },
        "qtTerminal": { "type": "number" },
        "qtRamal": { "type": "number" },
        "qtTotal": { "type": "number" },
        "voltageEndV": { "type": "number" },
        "ramalConductorId": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "ramalLengthMeters": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }]
        }
      }
    },
    "BtRadialWorstCase": {
      "type": "object",
      "required": ["worstTerminalNodeId", "cqtGlobal", "criticalPath", "qtTrafo"],
      "additionalProperties": false,
      "properties": {
        "worstTerminalNodeId": { "type": "string" },
        "cqtGlobal": { "type": "number" },
        "criticalPath": {
          "type": "array",
          "items": { "type": "string" }
        },
        "qtTrafo": { "type": "number" }
      }
    },
    "BtRadialConsistencyAlert": {
      "type": "object",
      "required": ["code", "message", "severity"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warn"] }
      }
    }
  }
}
