# SIS RUA Unified - Environment Variables (DEPRECATED FOR SECRETS)
# 
# SECURITY HARDENING: Most sensitive values are now handled via Docker Secrets
# in the './secrets' directory. See docker-compose.yml for details.
#
# Use this file ONLY for non-sensitive configuration if needed.

# (Sensitives below are for fallback or non-docker usage only)
# REDIS_PASSWORD=... (Use secrets/redis_password.txt instead)

# App Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8080

# ─── Supabase / Postgres jobs persistence ─────────────────────────────────
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
# Opt-in explícito. Se DATABASE_URL existir, o padrão já é true.
# USE_SUPABASE_JOBS=true
# MAINTENANCE_DB_CLEANUP_ENABLED=true
