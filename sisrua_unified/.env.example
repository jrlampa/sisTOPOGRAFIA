# ============================================
# SIS RUA Unified - Environment Configuration
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
NODE_ENV=development
PORT=8080
# Express trust proxy (rate limit and req.ip correctness behind reverse proxy)
# Examples:
# TRUST_PROXY=false                      -> local dev without proxy
# TRUST_PROXY=1                          -> trust first proxy hop (recommended for Cloud Run/reverse proxy)
# TRUST_PROXY=loopback, linklocal, uniquelocal
# TRUST_PROXY=10.0.0.0/8,127.0.0.1
TRUST_PROXY=false

# Admin token required for constants refresh/snapshot operational endpoints
# Required in all environments (including test/staging) for security hardening
CONSTANTS_REFRESH_TOKEN=change-me

# Optional Bearer token to protect /metrics endpoint.
# If defined, Prometheus/Grafana scrapers must send:
# Authorization: Bearer <METRICS_TOKEN>
# Leave empty ONLY when /metrics is strictly internal (private network/gateway).
# METRICS_TOKEN=change-me

# --------------------------------------------
# Frontend API Configuration (Optional)
# --------------------------------------------
# Override the API URL for the frontend
# By default, the frontend uses relative URLs (/api)
# which works both in development (via Vite proxy) and production
# VITE_API_URL=/api
# Production-only allowlist for absolute API origins (comma or space separated)
# Example: VITE_ALLOWED_API_ORIGINS=https://api.seudominio.com https://api-backup.seudominio.com
# VITE_ALLOWED_API_ORIGINS=

# Optional CSP extensions (space/comma separated).
# Keep empty unless strictly necessary.
# VITE_CSP_CONNECT_SRC=
# VITE_CSP_IMG_SRC=

# --------------------------------------------
# GROQ AI API (Required for AI-powered search)
# --------------------------------------------
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# --------------------------------------------
# Google Cloud Platform (Required for Production)
# --------------------------------------------
# Used for Google Cloud Tasks (async job processing)
# Required ONLY for Cloud Run deployment, NOT for local development

GCP_PROJECT=sisrua-producao
CLOUD_TASKS_LOCATION=southamerica-east1
CLOUD_TASKS_QUEUE=sisrua-queue

# Auto-populated after Cloud Run deployment
CLOUD_RUN_BASE_URL=http://localhost:8080

# Legacy webhook OIDC vars (currently not used by active routes)
# Keep commented unless a protected inbound Cloud Tasks webhook route is reintroduced.
# GCP_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
# CLOUD_RUN_SERVICE_URL=https://your-service-name.run.app

# --------------------------------------------
# Firestore (Storage with Circuit Breaker)
# --------------------------------------------
# Enable Firestore for persistent storage with quota monitoring
# In production, Firestore is enabled only when Supabase jobs is disabled
# In development, set this to 'true' to test Firestore locally
USE_FIRESTORE=false

# --------------------------------------------
# Supabase Jobs Persistence
# --------------------------------------------
# Enable Postgres persistence for async job status tracking.
# Defaults to true when DATABASE_URL is defined.
USE_SUPABASE_JOBS=true

# Firestore will automatically:
# - Monitor quotas in real-time (reads, writes, deletes, storage)
# - Trigger circuit breaker at 95% of quota
# - Auto-cleanup at 80% of storage (deletes oldest data first)
# - Fallback to memory if circuit breaker opens

# Firestore Quotas (Free Tier):
# - Storage: 1 GiB
# - Reads: 50,000/day
# - Writes: 20,000/day  
# - Deletes: 20,000/day

# Monitor quota usage via: GET /api/firestore/status

# --------------------------------------------
# Local Development Mode (Offline)
# --------------------------------------------
# Set to 'true' to disable all GCP services (Firestore, Cloud Tasks)
# Uses in-memory storage and local job queue instead
OFFLINE_MODE=true

# --------------------------------------------
# Notes for Local Development
# --------------------------------------------
# 1. You only need GROQ_API_KEY for AI search features
# 2. GCP variables are optional for local development
# 3. Docker Compose will use default values if not set
# 4. Redis is NOT required (Cloud Tasks handles job queue in production)
# 5. OFFLINE_MODE=true ensures 100% local operation without GCP credentials
