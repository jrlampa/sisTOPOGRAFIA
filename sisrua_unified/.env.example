# SIS RUA Unified - Environment Variables
# Copy this file to .env and update values with REAL secrets
# DO NOT commit .env to version control

# Redis Configuration
# SECURITY: Set a strong password (min 16 chars, alphanumeric + symbols)
REDIS_PASSWORD=your_strong_redis_password_here

# GROQ API Key (if using GROQ LLM)
GROQ_API_KEY=your_groq_api_key_here

