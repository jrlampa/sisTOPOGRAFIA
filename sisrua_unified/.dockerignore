# ─── Dependências (gerenciadas dentro do container) ──────────────────────────
node_modules
.npm
.venv
venv
ENV
__pycache__
*.pyc
*.pyo
*.pyd

# ─── Artefatos de build (reconstruídos dentro do container) ──────────────────
dist
.next
build

# ─── Controle de versão ───────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Arquivos de ambiente (segurança — nunca entram na imagem) ────────────────
.env
.env.local
.env.*.local
.env.secrets
.env.supabase
secrets/

# ─── Ferramentas de desenvolvimento ──────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store

# ─── Testes e cobertura ───────────────────────────────────────────────────────
.pytest_cache
coverage
.coverage
htmlcov
test-results
playwright-report
.lighthouseci

# ─── Artefatos e cache ────────────────────────────────────────────────────────
logs/*.log
public/dxf/*.dxf
public/dxf/*.zip
cache/*
!cache/.gitkeep
tmp/*
!tmp/.gitkeep
_quarantine
artifacts
scratch
download

# ─── Arquivos gerados ─────────────────────────────────────────────────────────
*_memorial_descritivo_*.pdf
npm-debug.log
DB_LOG.log
metadata.json

# ─── Arquivos Docker (não copiar para dentro da imagem) ───────────────────────
docker-compose.yml
docker-compose.*.yml
Dockerfile*
.dockerignore

# ─── Documentação (não necessária em runtime) ─────────────────────────────────
*.md
README*
CHANGELOG*
ARCHITECTURE*

# ─── Configs de teste e CI (não necessárias no container) ────────────────────
playwright.config.*
vitest.*.config.*
lighthouserc.json
pytest.ini
jest.config.*

# NOTA: tsconfig*.json e vite.config.* NÃO são excluídos.
# Eles são necessários para `tsc` e `vite build` no estágio node-build.
vite-env.d.ts
README_LOCAL.md
.bandit
.gitleaks.toml
lighthouserc.json
test-metrics.config.json
