{
  "name": "sisrua-unified",
  "private": true,
  "version": "0.9.0",
  "description": "Sistema de Exportação OSM para DXF - IMPORTANT: Do not update version manually. Use ./scripts/update-version.sh instead. See VERSIONING.md for details.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "client": "vite",
    "build": "tsc && vite build",
    "build:all": "node scripts/run-build-release.js",
    "build:all:ps": "powershell -ExecutionPolicy Bypass -File scripts/build_release.ps1",
    "build:all:bash": "bash scripts/build_release.sh",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "version:update": "bash scripts/update-version.sh",
    "version:check": "bash scripts/check-version.sh",
    "docker:build": "docker build -t sisrua-unified:latest .",
    "docker:run": "docker run -p 8080:8080 --env-file .env sisrua-unified:latest",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml up --build",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f app",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:frontend": "eslint src/ --ext ts,tsx --max-warnings 0",
    "lint:backend": "eslint server/ --ext ts --max-warnings 0",
    "lint:backend:strict": "eslint server/ --ext ts --max-warnings 0",
    "typecheck:frontend": "tsc --noEmit --project tsconfig.json",
    "typecheck:backend": "tsc --noEmit --project tsconfig.server.json",
    "ci:frontend": "npm run lint:frontend && npm run typecheck:frontend && npm run test:frontend && npm run test:frontend:risk && npm run build",
    "a11y:smoke": "playwright test e2e/a11y-smoke.spec.ts --config playwright.a11y.config.ts",
    "lhci": "echo 'lhci foi removido por hardening de dependencias. Use: npx lighthouse <url> ou mcp_io_github_chr_lighthouse_audit'",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json,md}\" \"server/**/*.{ts,js,json,md}\" \"shared/**/*.{ts,tsx,js,json,md}\" \"tests/**/*.{ts,tsx,js,json,md}\" \"e2e/**/*.{ts,tsx,js,json,md}\" \"*.{json,js,cjs,mjs,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json,md}\" \"server/**/*.{ts,js,json,md}\" \"shared/**/*.{ts,tsx,js,json,md}\" \"tests/**/*.{ts,tsx,js,json,md}\" \"e2e/**/*.{ts,tsx,js,json,md}\" \"*.{json,js,cjs,mjs,md}\"",
    "test": "npm run test:frontend && npm run test:backend",
    "test:unit": "npm run test:frontend:unit && npm run test:backend:unit",
    "test:frontend:unit": "vitest run --config vitest.config.ts",
    "test:backend:unit": "vitest run --config vitest.backend.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:frontend": "vitest run --config vitest.config.ts --coverage",
    "test:frontend:risk": "vitest run --config vitest.risk.config.ts --coverage",
    "test:backend": "vitest run --config vitest.backend.config.ts --coverage",
    "test:backend:debug": "vitest --config vitest.backend.config.ts",
    "test:contract": "vitest run --config vitest.backend.config.ts server/tests/authContract.test.ts server/tests/billingContract.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:release:smoke": "playwright test e2e/release-smoke.spec.ts e2e/constants-observability.spec.ts --config playwright.release-smoke.config.ts",
    "ci:e2e:flake-check": "node scripts/ci/analyze-playwright-flakiness.mjs --lastRun test-results/.last-run.json --report test-results/release-smoke-report.json --out artifacts/ci/flakiness-report.json",
    "ci:e2e:snapshot-slo": "node scripts/ci/enforce-snapshot-slo.mjs --report test-results/release-smoke-report.json --baseline .github/slo/snapshot-slo-baseline.json --out artifacts/ci/snapshot-slo-report.json",
    "ci:normative-checklist-gate": "node scripts/ci/enforce-normative-checklist.mjs --checklist docs/NORMATIVE_VALIDATION_CHECKLIST.md --policy .github/normative-checklist-policy.json --package package.json --out artifacts/ci/normative-checklist-report.json",
    "ci:d7-go-parcial-gate": "node scripts/ci/enforce-d7-go-parcial-evidence.mjs --evidence .github/d7-go-parcial-evidence.json --out artifacts/ci/d7-go-parcial-report.json",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:backend && npm run test:frontend && npm run test:integration && npm run test:e2e -- --grep @smoke",
    "test:qa:regression": "npm run test:unit && npm run test:integration && npm run test:e2e:release:smoke",
    "cqt:parity-report": "tsx scripts/generate-cqt-parity-report.ts",
    "cqt:parity-check": "tsx scripts/generate-cqt-parity-report.ts --check",
    "cqt:parity-check:strict": "tsx scripts/generate-cqt-parity-report.ts --check --require-workbook-audit",
    "cqt:workbook-audit": "python scripts/audit_cqt_workbook.py",
    "cqt:workbook-audit:light": "python scripts/audit_cqt_workbook.py --workbook \"Light_estudo/CQTsimplificado_BECO DO MATA 7 - PARIDADE_FINAL.xlsx\"",
    "cqt:workbook-audit:check": "python scripts/audit_cqt_workbook.py --check",
    "security:audit": "npm audit --omit=dev --audit-level=critical",
    "security:policy-gate": "npm run security:audit",
    "security:sbom:node": "node scripts/ci/generate-sbom-node.mjs",
    "security:audit:fix": "npm audit fix",
    "security:check": "npm run security:audit && echo '\n--- Security audit complete ---'",
    "ci:checkpoint-gate": "node scripts/ci/enforce-checkpoints-timeline.mjs",
    "ci:non-negotiables": "node scripts/ci/enforce-non-negotiables.mjs",
    "ci:db:predeploy": "python scripts/predeploy_db_healthcheck.py",
    "security:python": "bandit -c .bandit -r py_engine/ -f json -o artifacts/bandit-report.json || bandit -c .bandit -r py_engine/ -ll",
    "security:python:ci": "bandit -c .bandit -r py_engine/ -ll --exit-zero -f json -o artifacts/bandit-report.json",
    "security:pip:audit": "pip-audit -r py_engine/requirements.txt --format json -o artifacts/pip-audit-report.json || pip-audit -r py_engine/requirements.txt",
    "security:pip:compile": "pip-compile py_engine/requirements.in --output-file=py_engine/requirements.txt",
    "security:pip:check": "pip-compile --check py_engine/requirements.in --output-file=py_engine/requirements.txt",
    "security:all": "npm run security:audit && npm run security:python:ci && npm run security:pip:audit && npm run security:pip:check && echo '\\n--- Varredura de segurança completa ---'",
    "naming:check:bt": "node scripts/check-bt-naming.js",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "setup:local:bash": "bash scripts/setup-local.sh",
    "health:check": "powershell -ExecutionPolicy Bypass -File scripts/health-check.ps1",
    "health:check:bash": "bash scripts/health-check.sh",
    "postinstall": "echo '\n✅ Configuração concluída!\n\n🐳 RECOMENDADO: Use Docker para a melhor experiência:\n   npm run docker:dev\n\n💻 Ou instale manualmente as dependências Python:\n   pip install -r py_engine/requirements.txt\n'",
    "test:metrics": "node scripts/test-suite-metrics.js",
    "test:load": "node scripts/load-test-baseline.js",
    "backup:external": "node scripts/backup-external-gcs.js",
    "coverage:consolidate": "node scripts/consolidate-coverage.js",
    "coverage:policy": "node scripts/check-coverage-policy.js",
    "coverage:policy:strict": "node scripts/check-coverage-policy.js --strict",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google-cloud/storage": "^7.11.0",
    "@google-cloud/tasks": "^6.2.1",
    "@supabase/supabase-js": "^2.105.1",
    "@types/multer": "^2.0.0",
    "@types/proj4": "^2.5.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.2",
    "fast-xml-parser": "^5.7.2",
    "framer-motion": "^12.34.0",
    "helmet": "^8.1.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "multer": "^2.0.2",
    "postgres": "^3.4.9",
    "posthog-js": "^1.367.0",
    "proj4": "^2.20.2",
    "prom-client": "^15.1.3",
    "python-shell": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.6",
    "react-is": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.7.0",
    "stripe": "^22.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "react-router-dom": "^7.14.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.19.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.4",
    "postcss": "^8.4.35",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
