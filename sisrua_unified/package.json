{
  "name": "sisrua-unified",
  "private": true,
  "version": "1.0.0",
  "description": "Sistema de Exportação OSM para DXF - IMPORTANT: Do not update version manually. Use ./scripts/update-version.sh instead. See VERSIONING.md for details.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "client": "vite",
    "build": "tsc && vite build",
    "build:all": "node scripts/run-build-release.js",
    "build:all:ps": "powershell -ExecutionPolicy Bypass -File scripts/build_release.ps1",
    "build:all:bash": "bash scripts/build_release.sh",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "version:update": "bash scripts/update-version.sh",
    "version:check": "bash scripts/check-version.sh",
    "docker:build": "docker build -t sisrua-unified:latest .",
    "docker:run": "docker run -p 8080:8080 --env-file .env sisrua-unified:latest",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 300",
    "lint:frontend": "eslint src/ --ext ts,tsx --max-warnings 300",
    "lint:backend": "eslint server/ --ext ts --max-warnings 0",
    "typecheck:frontend": "tsc --noEmit --project tsconfig.json",
    "typecheck:backend": "tsc --noEmit --project tsconfig.server.json",
    "ci:frontend": "npm run lint:frontend && npm run typecheck:frontend && npm run test:frontend && npm run test:frontend:risk && npm run build",
    "a11y:smoke": "playwright test e2e/a11y-smoke.spec.ts --config playwright.a11y.config.ts",
    "lhci": "lhci autorun || echo 'LHCI warning: non-blocking run'",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "vitest run --config vitest.config.ts --coverage",
    "test:frontend:risk": "vitest run --config vitest.risk.config.ts --coverage",
    "test:backend": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:backend && npm run test:frontend && npm run test:e2e -- --grep @smoke",
    "cqt:parity-report": "tsx scripts/generate-cqt-parity-report.ts",
    "cqt:parity-check": "tsx scripts/generate-cqt-parity-report.ts --check",
    "cqt:parity-check:strict": "tsx scripts/generate-cqt-parity-report.ts --check --require-workbook-audit",
    "cqt:workbook-audit": "python scripts/audit_cqt_workbook.py",
    "cqt:workbook-audit:light": "python scripts/audit_cqt_workbook.py --workbook \"Light_estudo/CQTsimplificado_BECO DO MATA 7 - PARIDADE_FINAL.xlsx\"",
    "cqt:workbook-audit:check": "python scripts/audit_cqt_workbook.py --check",
    "security:audit": "npm audit --omit=dev --audit-level=critical",
    "security:policy-gate": "npm run security:audit",
    "security:sbom:node": "node scripts/generate-node-sbom.js",
    "security:audit:fix": "npm audit fix",
    "security:check": "npm run security:audit && echo '\n--- Security audit complete ---'",
    "security:python": "bandit -c .bandit -r py_engine/ -f json -o artifacts/bandit-report.json || bandit -c .bandit -r py_engine/ -ll",
    "security:python:ci": "bandit -c .bandit -r py_engine/ -ll --exit-zero -f json -o artifacts/bandit-report.json",
    "security:pip:audit": "pip-audit -r py_engine/requirements.txt --format json -o artifacts/pip-audit-report.json || pip-audit -r py_engine/requirements.txt",
    "security:sbom:node": "node -e \"const p=require('./package.json');const s={bomFormat:'CycloneDX',specVersion:'1.4',version:1,serialNumber:'urn:uuid:'+(()=>{const c='10000000-1000-4000-8000-100000000000';return c.replace(/[018]/g,x=>(+x^crypto.getRandomValues(new Uint8Array(1))[0]&15>>+x/4).toString(16))})(),components:Object.entries({...p.dependencies,...p.devDependencies}).map(([n,v])=>({type:'library',name:n,version:v.replace(/[^\\d.]/g,'')}))};require('fs').mkdirSync('artifacts',{recursive:true});require('fs').writeFileSync('artifacts/sbom-node.json',JSON.stringify(s,null,2));console.log('SBOM gerado: artifacts/sbom-node.json')\"",
    "security:all": "npm run security:audit && npm run security:python:ci && npm run security:pip:audit && echo '\\n--- Varredura de segurança completa ---'",
    "naming:check:bt": "node scripts/check-bt-naming.js",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "setup:local:bash": "bash scripts/setup-local.sh",
    "health:check": "powershell -ExecutionPolicy Bypass -File scripts/health-check.ps1",
    "health:check:bash": "bash scripts/health-check.sh",
    "postinstall": "echo '\n✅ Setup complete!\n\n🐳 RECOMMENDED: Use Docker for the best experience:\n   npm run docker:dev\n\n💻 Or install Python dependencies manually:\n   pip install -r py_engine/requirements.txt\n'"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google-cloud/tasks": "^6.2.1",
    "@types/multer": "^2.0.0",
    "@types/proj4": "^2.5.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.34.0",
    "groq-sdk": "^0.37.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.564.0",
    "multer": "^2.0.2",
    "postgres": "^3.4.9",
    "posthog-js": "^1.367.0",
    "proj4": "^2.20.2",
    "prom-client": "^15.1.3",
    "python-shell": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.19.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^1.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^29.7.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.35",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^1.3.1",
    "wait-on": "^9.0.4"
  }
}
