{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/server",
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": ["server", "shared", "types.ts"],
  "exclude": ["server/tests", "**/*.test.ts", "**/*.spec.ts"]
}
